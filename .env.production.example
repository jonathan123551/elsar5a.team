# Production environment template for Render deployment.
#
# render.yaml wires most of these for you automatically. The two values you
# MUST set yourself in the Render dashboard (Environment tab) are marked
# REQUIRED below.
#
#   1. APP_KEY      -> generate one with:
#                      php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
#                      then paste the value (including the `base64:` prefix)
#                      into Render's APP_KEY env var.
#
#   2. DB_URL       -> the Postgres connection string from Neon. It looks like:
#                      postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

APP_NAME="Elsar5a Team"
APP_ENV=production
APP_KEY=                                # REQUIRED — see note above
APP_DEBUG=false
APP_URL=https://elsar5ateam.onrender.com

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (Neon Postgres) ---
DB_CONNECTION=pgsql
DB_URL=                                 # REQUIRED — paste Neon connection string

# --- Sessions / cache / queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Trust Render's load balancer
TRUSTED_PROXIES=*

VITE_APP_NAME="${APP_NAME}"
